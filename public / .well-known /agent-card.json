  "skills": [
    {
      "id": "whaber_get_safe_pickup_point",
      "name": "Get Verified Safe Pickup Point",
      "description": "Returns physically verified safe pickup coordinates for a given location, time window, and service type. Coordinates are validated by licensed carriers operating in the zone. Output includes landmark reference, estimated wait time, and compliance status. NEVER includes internal risk scoring or safety margins — those remain proprietary moat data.",
      "category": "operational-verification",
      "tags": [
        "pickup",
        "safety",
        "compliance",
        "ground-truth",
        "verified-coordinates"
      ],
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json"
      ],
      "examples": [
        {
          "input": {
            "location_id": "quito_centro_historico",
            "time_window": "23:00",
            "pax_count": 2,
            "trip_type": "standard"
          },
          "output": {
            "pickup_point": {
              "coordinates": {
                "lat": -0.2201641,
                "lng": -78.5123274
              },
              "label": "Plaza de la Independencia — North Side",
              "landmark": "Near Palacio de Gobierno entrance"
            },
            "estimated_wait_minutes": 8,
            "ops_window": {
              "suggested_departure": "22:52",
              "window_minutes": 15
            },
            "compliance_status": "verified"
          }
        }
      ],
      "inputSchema": {
        "type": "object",
        "required": [
          "location_id",
          "time_window",
          "pax_count"
        ],
        "properties": {
          "location_id": {
            "type": "string",
            "description": "Place Graph node ID (e.g., 'quito_centro_historico', 'quito_aeropuerto_uio')"
          },
          "time_window": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$",
            "description": "Local pickup time in HH:MM format"
          },
          "pax_count": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10,
            "description": "Number of passengers including those with bulky luggage"
          },
          "trip_type": {
            "type": "string",
            "enum": [
              "standard",
              "vip",
              "corporate",
              "airport"
            ],
            "default": "standard",
            "description": "Service tier — determines commercial rules applied"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "pickup_point": {
            "type": "object",
            "properties": {
              "coordinates": {
                "type": "object",
                "properties": {
                  "lat": {
                    "type": "number"
                  },
                  "lng": {
                    "type": "number"
                  }
                }
              },
              "label": {
                "type": "string"
              },
              "landmark": {
                "type": "string"
              }
            }
          },
          "estimated_wait_minutes": {
            "type": "number"
          },
          "ops_window": {
            "type": "object",
            "properties": {
              "suggested_departure": {
                "type": "string"
              },
              "window_minutes": {
                "type": "number"
              }
            }
          },
          "compliance_status": {
            "type": "string",
            "enum": [
              "verified",
              "pending_revalidation"
            ]
          }
        }
      },
      "readOnly": true,
      "idempotent": true,
      "sla": {
        "averageLatency": "120ms",
        "p99Latency": "300ms",
        "circuitBreakerThreshold": "300ms"
      }
