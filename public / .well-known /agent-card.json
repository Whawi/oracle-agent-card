    {
      "id": "whaber_calculate_ops_window",
      "name": "Calculate Operational Window",
      "description": "Computes the recommended departure time and safe arrival window for a trip between two Place Graph nodes. Incorporates real traffic weight, weather impact, municipal restrictions, and historical execution data. Returns suggested departure time, total window duration, and confidence level. Output is operational guidance — NEVER includes proprietary safety margins or raw ops modifiers.",
      "category": "timing-verification",
      "tags": [
        "timing",
        "ops-window",
        "traffic",
        "weather",
        "execution-data"
      ],
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json"
      ],
      "examples": [
        {
          "input": {
            "origin_node": "quito_aeropuerto_uio",
            "destination_node": "quito_ibis_hotel",
            "arrival_target": "14:00",
            "pax_count": 2
          },
          "output": {
            "suggested_departure": "13:12",
            "window_minutes": 18,
            "arrival_range": {
              "earliest": "13:54",
              "latest": "14:12"
            },
            "confidence": "high",
            "traffic_context": "moderate — afternoon peak begins 14:30"
          }
        }
      ],
      "inputSchema": {
        "type": "object",
        "required": [
          "origin_node",
          "destination_node",
          "arrival_target"
        ],
        "properties": {
          "origin_node": {
            "type": "string",
            "description": "Place Graph node ID for origin"
          },
          "destination_node": {
            "type": "string",
            "description": "Place Graph node ID for destination"
          },
          "arrival_target": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}$",
            "description": "Target arrival time in HH:MM format"
          },
          "pax_count": {
            "type": "integer",
            "minimum": 1,
            "default": 1
          },
          "date": {
            "type": "string",
            "format": "date",
            "description": "Optional date for seasonal traffic patterns"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "suggested_departure": {
            "type": "string",
            "description": "Recommended departure time HH:MM"
          },
          "window_minutes": {
            "type": "number",
            "description": "Total operational window width"
          },
          "arrival_range": {
            "type": "object",
            "properties": {
              "earliest": {
                "type": "string"
              },
              "latest": {
                "type": "string"
              }
            }
          },
          "confidence": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "traffic_context": {
            "type": "string",
            "description": "Human-readable traffic condition summary"
          }
        }
      },
      "readOnly": true,
      "idempotent": true,
      "sla": {
        "averageLatency": "150ms",
        "p99Latency": "300ms"
      }
    },
    {
      "id": "whaber_validate_carrier_compliance",
      "name": "Validate Carrier Compliance",
      "description": "Verifies that a carrier is authorized to operate for the specified route, time window, and service type. Checks municipal licensing, vehicle certification, insurance validity, and driver authorization. Returns compliance status with expiration dates for re-validation. Output is binary verification — NEVER includes internal carrier scoring, incident history, or performance metrics.",
      "category": "compliance-verification",
      "tags": [
        "carrier",
        "compliance",
        "licensing",
        "verification"
      ],
      "inputModes": [
        "application/json"
      ],
      "outputModes": [
        "application/json"
      ],
      "examples": [
        {
          "input": {
            "carrier_id": "CAR_QUI_087",
            "route_type": "airport",
            "service_window": "22:00-06:00"
          },
          "output": {
            "compliance_status": "valid",
            "license_type": "ANT-A1",
            "valid_until": "2026-11-15",
            "restrictions": [
              "airport-only",
              "vip-certified"
            ],
            "last_verified": "2026-04-08"
          }
        }
      ],
      "inputSchema": {
        "type": "object",
        "required": [
          "carrier_id"
        ],
        "properties": {
          "carrier_id": {
            "type": "string",
            "description": "Unique carrier identifier in Whaber system"
          },
          "route_type": {
            "type": "string",
            "enum": [
              "airport",
              "city",
              "intercity"
            ],
            "default": "city"
          },
          "service_window": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}-\\d{2}:\\d{2}$",
            "description": "Time range for service (e.g., '22:00-06:00')"
          }
        }
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "compliance_status": {
            "type": "string",
            "enum": [
              "valid",
              "expired",
              "restricted",
              "suspended"
            ]
          },
          "license_type": {
            "type": "string",
            "description": "Municipal license classification"
          },
          "valid_until": {
            "type": "string",
            "format": "date"
          },
          "restrictions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_verified": {
            "type": "string",
            "format": "date"
          }
        }
      },
      "readOnly": true,
      "idempotent": true,
      "sla": {
        "averageLatency": "80ms",
        "p99Latency": "200ms"
      }
    },
